---
import BaseLayout from "../layouts/BaseLayout.astro";

const lastUpdated = "June 2026";
const location = "Hamburg, Germany";

const externalLinkAttrs = {
  target: "_blank",
  rel: "noopener noreferrer",
};

const linkClass =
  "text-interactive-default decoration-border-default hover:decoration-interactive-default underline underline-offset-2 transition-colors";

const nowItems = [
  "Designing at Lucanet and pushing AI initiatives",
  "Experimenting a lot with AI personally",
  "Trying out different food options and investing in health",
  "Working on my portfolio version 247",
];

const projects = [
  {
    title: "OpenSkies",
    description: "Free sky photos to download and use.",
    href: "https://openskies.photos/",
  },
  {
    title: "Safari Favicon",
    description:
      "Researching Safari favicon behavior and building testing tools.",
    href: "https://www.npmjs.com/package/safari-favicon",
  },
  {
    title: "Ambient",
    description: "My first Figma plugin, allows to toggle page backgrounds.",
    href: "https://www.figma.com/community/plugin/1641224666051612052/ambient",
  },
];
---

<BaseLayout title="Now" description="What I'm focused on right now." wide>
  <div class="flex w-full max-w-[640px] flex-col gap-12">
    <div class="flex flex-col gap-3">
      <h1 class="text-headline-medium text-foreground-primary">Now</h1>
      <p class="text-body-small text-foreground-secondary">
        Updated {lastUpdated} · {location}
      </p>
    </div>

    <section class="flex flex-col">
      <h2 class="text-body-small-bold text-foreground-primary">Now</h2>
      <ul class="text-body-small text-foreground-secondary list-disc pl-6">
        {nowItems.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="flex flex-col">
      <h2 class="text-body-small-bold text-foreground-primary">Projects</h2>
      <ul class="text-interactive-default list-disc pl-6">
        {
          projects.map((project) => (
            <li>
              <a href={project.href} class={linkClass} {...externalLinkAttrs}>
                {project.title}: {project.description}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>

  <img
    src="/images/now/now.jpg"
    alt="Concrete building with vertical windows against a cloudy sky"
    width="1024"
    height="576"
    class="aspect-2784/1566 w-full rounded-md object-cover object-[center_35%]"
  />
</BaseLayout>
