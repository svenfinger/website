---
import BaseLayout from "../layouts/BaseLayout.astro";
import Divider from "../components/Divider.astro";

const externalLinkAttrs = {
  target: "_blank",
  rel: "noopener noreferrer",
};

const linkClass =
  "text-interactive-default decoration-border-default hover:decoration-interactive-default underline underline-offset-2 transition-colors";

const socials = [
  { label: "x.com/svenfinger", href: "https://x.com/svenfinger" },
  {
    label: "linkedin.com/in/svenfinger",
    href: "https://www.linkedin.com/in/svenfinger/",
  },
  { label: "github.com/svenfinger", href: "https://github.com/svenfinger" },
  { label: "figma.com/sven", href: "https://figma.com/@sven" },
  { label: "cursor.com/@sven", href: "https://cursor.com/@sven" },
];
---

<BaseLayout title="Contact" description="Get in touch.">
  <h1 class="text-headline-medium text-foreground-primary">Contact</h1>

  <div class="flex flex-col gap-6">
    <p class="text-body-small text-foreground-secondary">
      Always happy to hear from people building thoughtful things — whether it's
      a collaboration, a side project, or just a good conversation.
    </p>
    <div class="text-body-small flex gap-6">
      <a
        href="https://x.com/svenfinger"
        class={linkClass}
        {...externalLinkAttrs}
      >
        Message on X
      </a>
      <a href="mailto:hi@svenfinger.com" class={linkClass}>Send email</a>
    </div>
  </div>

  <Divider />

  <section class="flex flex-col">
    <h2 class="text-body-small-bold text-foreground-primary">Socials</h2>
    <ul class="text-body-small text-interactive-default list-disc pl-6">
      {
        socials.map(({ label, href }) => (
          <li>
            <a href={href} class={linkClass} {...externalLinkAttrs}>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
