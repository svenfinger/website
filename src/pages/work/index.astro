---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const work = (
  await getCollection("work", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => {
  const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
  const orderB = b.data.order ?? Number.POSITIVE_INFINITY;

  if (orderA !== orderB) return orderA - orderB;

  return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});
---

<BaseLayout title="Work" description="Selected projects and case studies.">
  <h1 class="text-3xl font-bold">Work</h1>

  <ul class="mt-8 space-y-8">
    {
      work.map((entry) => (
        <li class="border-border-subtle border-b pb-8 last:border-b-0">
          <h2 class="text-xl font-semibold">{entry.data.title}</h2>
          <p class="text-foreground-secondary mt-2">{entry.data.summary}</p>
          {(entry.data.year || entry.data.role) && (
            <p class="text-foreground-secondary mt-2 text-sm">
              {[entry.data.year, entry.data.role].filter(Boolean).join(" · ")}
            </p>
          )}
        </li>
      ))
    }
  </ul>
</BaseLayout>
