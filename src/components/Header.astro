---
import Logomark from "./Logomark.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/work", label: "Work" },
  { href: "/now", label: "Now" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  const path = href.replace(/\/$/, "") || "/";
  return currentPath === path;
}
---

<header class="flex w-full items-center justify-between py-6">
  <a
    href="/"
    aria-label="Home"
    class="flex size-6 items-center justify-center rounded-md bg-blue-600 text-white"
  >
    <Logomark class="size-[16.8px]" />
  </a>

  <nav aria-label="Main">
    <ul class="flex items-center gap-6">
      {
        navItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "text-body-small hover:text-foreground-primary transition-colors",
                isActive(href)
                  ? "text-foreground-primary"
                  : "text-foreground-secondary",
              ]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
