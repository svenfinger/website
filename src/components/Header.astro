---
const navItems = [
  { href: "/", label: "Index" },
  { href: "/about", label: "About" },
  { href: "/work", label: "Work" },
  { href: "/now", label: "Now" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  const path = href.replace(/\/$/, "") || "/";
  return currentPath === path;
}
---

<header class="border-border-subtle bg-background-primary border-b px-6">
  <div class="mx-auto flex max-w-screen-2xl items-center gap-6 py-6">
    <div class="flex min-w-0 flex-1 items-center">
      <a href="/" class="text-foreground-primary" aria-label="Home">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="size-6"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M16 6.87867C16 7.14389 16.1054 7.39824 16.2929 7.58578L16.4142 7.70711C16.6018 7.89464 16.8561 8 17.1213 8H23C23.5523 8 24 8.44772 24 9V15C24 15.5523 23.5523 16 23 16H17.1201C16.8548 16 16.6005 16.1054 16.413 16.2929L16.2929 16.413C16.1054 16.6005 16 16.8548 16 17.1201V23C16 23.5523 15.5523 24 15 24H9C8.44772 24 8 23.5523 8 23V17.1213C8 16.8561 7.89464 16.6018 7.70711 16.4142L7.58578 16.2929C7.39824 16.1054 7.14389 16 6.87867 16H1C0.447715 16 0 15.5523 0 15V9C0 8.44772 0.447715 8 1 8H6.87623C7.14145 8 7.3958 7.89464 7.58334 7.70711L7.70711 7.58334C7.89464 7.3958 8 7.14145 8 6.87623V1C8 0.447715 8.44772 0 9 0H15C15.5523 0 16 0.447715 16 1V6.87867ZM8.29289 8.41178C8.10536 8.59931 8 8.85367 8 9.11889V14.8787C8 15.1439 8.10536 15.3982 8.29289 15.5858L8.41422 15.7071C8.60176 15.8946 8.85611 16 9.12133 16H14.8775C15.1427 16 15.397 15.8946 15.5846 15.7071L15.7071 15.5846C15.8946 15.397 16 15.1427 16 14.8775V9.12133C16 8.85611 15.8946 8.60176 15.7071 8.41422L15.5858 8.29289C15.3982 8.10536 15.1439 8 14.8787 8H9.11889C8.85367 8 8.59931 8.10536 8.41178 8.29289L8.29289 8.41178Z"
            fill="currentColor"></path>
        </svg>
      </a>
    </div>

    <nav aria-label="Main">
      <ul class="flex items-center gap-12">
        {
          navItems.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  "hover:text-foreground-primary text-base leading-6 transition-colors",
                  isActive(href)
                    ? "text-foreground-primary"
                    : "text-foreground-secondary",
                ]}
                aria-current={isActive(href) ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex min-w-0 flex-1 items-center justify-end gap-12">
      <a
        href="/socials"
        class="text-foreground-secondary hover:text-foreground-primary text-base leading-6 transition-colors"
      >
        Socials
      </a>
      <a
        href="/contact"
        class="border-border-subtle text-foreground-secondary hover:text-foreground-primary rounded-full border px-3 py-1 text-base leading-6 transition-colors"
      >
        Contact
      </a>
    </div>
  </div>
</header>
