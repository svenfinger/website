---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/work', label: 'Work' },
	{ href: '/now', label: 'Now' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
	const path = href.replace(/\/$/, '') || '/';
	return currentPath === path;
}
---

<header class="border-b border-border-subtle">
	<div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
		<a href="/" class="text-lg font-semibold tracking-tight text-foreground-primary">Website</a>

		<div class="flex items-center gap-4">
			<nav aria-label="Main">
				<ul class="flex gap-6">
					{navItems.map(({ href, label }) => (
						<li>
							<a
								href={href}
								class:list={[
									'text-sm transition-colors hover:text-foreground-primary',
									isActive(href)
										? 'font-semibold text-foreground-primary'
										: 'text-foreground-secondary',
								]}
								aria-current={isActive(href) ? 'page' : undefined}
							>
								{label}
							</a>
						</li>
					))}
				</ul>
			</nav>
			<ThemeToggle />
		</div>
	</div>
</header>
